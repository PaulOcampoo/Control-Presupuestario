{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    { "path": "/api/cron/recordatorio-impuestos", "schedule": "0 15 17 * *" },
    { "path": "/api/cron/alertas-vencimiento", "schedule": "0 15 * * *" }
  ]
}
