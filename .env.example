# PostgreSQL connection string (Neon, Supabase, o cualquier proveedor compatible)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Solo en desarrollo local sin SSL:
# DATABASE_URL=postgresql://user:password@localhost/control_presupuestal

# Clave secreta para firmar las sesiones de login (obligatoria, usa un valor
# largo y aleatorio en producción — genera una con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=cambia-esto-por-un-valor-aleatorio-largo

# Credenciales del primer usuario administrador (solo se usan una vez, la
# primera vez que la base de datos no tiene ningún usuario). Cámbialas
# desde la pestaña "Usuarios" en cuanto inicies sesión.
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# Clave de la API de Claude (Anthropic) — requerida solo para la carga de
# Contrato PDF (extracción automática de datos). Sin esta variable, esos
# endpoints responden 500 con un mensaje claro; el resto de la app funciona
# igual sin ella.
ANTHROPIC_API_KEY=

# Secreto que Vercel Cron envía como "Authorization: Bearer <CRON_SECRET>"
# al llamar POST /api/cron/recordatorio-impuestos (ver vercel.json → "crons").
# Sin esta variable, ese endpoint responde 500 con un mensaje claro. Genera
# uno con: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=
